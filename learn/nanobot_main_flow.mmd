flowchart TD
    A["Channel 或 CLI 接收用户输入"] --> B["MessageBus.publish_inbound"]
    B --> C["AgentLoop.run 消费 InboundMessage"]
    C --> D["AgentLoop._dispatch：session lock 和 pending queue"]
    D --> E["SessionManager.get_or_create"]
    E --> F["RESTORE：恢复运行时 checkpoint 和 pending user turn"]
    F --> G["COMPACT：AutoCompact 准备 session summary"]
    G --> H["COMMAND：slash command 快捷处理或普通分发"]
    H --> I["BUILD：读取历史并构造 initial messages"]
    I --> J["ContextBuilder.build_messages"]
    J --> K["AgentLoop._run_agent_loop"]
    K --> L["AgentRunner.run"]
    L --> M["Provider chat_with_retry 或 chat_stream_with_retry"]
    M --> N{"LLMResponse 有可执行 tool_calls 吗？"}
    N -->|有| O["ToolRegistry 提供 schema 并执行工具"]
    O --> P["追加 tool result messages"]
    P --> M
    N -->|没有| Q["最终 assistant message"]
    Q --> R["SAVE：_save_turn 写入本轮新消息"]
    R --> S["SessionManager.save 写入 JSONL"]
    S --> T["RESPOND：组装 OutboundMessage"]
    T --> U["MessageBus.publish_outbound"]
    U --> V["ChannelManager 或 CLI 渲染结果"]

    subgraph Context["上下文组装"]
        I
        J
        W["system prompt：identity、AGENTS、tool contract、memory、skills"]
        X["history：Session.get_history 合法历史后缀"]
        Y["当前用户内容加运行时元数据"]
        W --> J
        X --> J
        Y --> J
    end

    subgraph Tools["工具调用循环"]
        L
        M
        N
        O
        P
    end

    subgraph Memory["Session 和记忆"]
        E
        G
        R
        S
        Z["Consolidator 和 MemoryStore 归档长上下文"]
        G --> Z
        R --> Z
    end
